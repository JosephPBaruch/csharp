from pathlib import Path

gitignore_content = """# Build results
bin/
obj/
[Bb]uild/
[Bb]uilds/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# .NET generated files
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

# Visual Studio
.vs/
*.userprefs
*.ncrunch*
*.localhistory/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Rider / JetBrains
.idea/
*.sln.iml

# NuGet
*.nupkg
*.snupkg
packages/
project.lock.json
project.assets.json
artifacts/

# Test results and coverage
TestResults/
*.trx
*.coverage
*.coveragexml
coverage/
coverage-results/
coveragereport/
lcov.info

# Logs
*.log
logs/

# Environment files
.env
.env.*
!.env.example

# User secrets should not be committed
secrets.json

# Publish output
publish/
Published/
*.publishsettings

# Temporary files
*.tmp
*.temp
*.swp
*.bak
*.orig

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# Recycle Bin files
$RECYCLE.BIN/

# C# interactive / script output
*.csx~
"""

path = Path("/mnt/data/.gitignore")
path.write_text(gitignore_content, encoding="utf-8")

path.as_posix()
